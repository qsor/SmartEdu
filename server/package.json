{
  "name": "smartedu-backend",
  "version": "1.0.0",
  "description": "Backend for SmartEdu platform",
  "type": "module",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -- tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "tsc": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.38.3",
    "drizzle-kit": "^0.30.1",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.21",
    "@types/pg": "^8.11.10",
    "dotenv": "^16.4.7",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}