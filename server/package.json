{
  "name": "smartedu-backend",
  "version": "1.0.0",
  "description": "Backend for SmartEdu platform",
  "type": "module",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "dotenv -- tsx watch src/server.ts",
    "build": "npm run prisma:generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "tsc": "tsc --noEmit",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@js-temporal/polyfill": "^0.5.1",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jose": "^6.2.3",
    "pg": "^8.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.19",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
